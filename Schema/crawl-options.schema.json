{
  "$id": "https://example.com/scrapehound/schema/crawl-options.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scrapehound Crawl Options",
  "type": "object",
  "description": "Configuration contract for CrawlOptions and the TOML loader. The runtime accepts [storage], [http], and [crawl] TOML sections; this JSON schema documents the normalized option object.",
  "additionalProperties": false,
  "properties": {
    "db_path": {
      "type": "string",
      "default": "scrapehound.sqlite"
    },
    "transport": {
      "type": "string",
      "enum": [
        "raw_socket",
        "library"
      ],
      "default": "raw_socket"
    },
    "user_agent": {
      "type": "string"
    },
    "max_pages": {
      "type": "integer",
      "minimum": 1,
      "default": 100
    },
    "max_depth": {
      "type": "integer",
      "minimum": 0,
      "default": 2
    },
    "max_response_bytes": {
      "type": "integer",
      "minimum": 1,
      "default": 2097152
    },
    "connect_timeout": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 5.0
    },
    "read_timeout": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 10.0
    },
    "total_timeout": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 30.0
    },
    "redirect_limit": {
      "type": "integer",
      "minimum": 0,
      "default": 5
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 2
    },
    "min_delay_seconds": {
      "type": "number",
      "minimum": 0,
      "default": 1.0
    },
    "obey_robots": {
      "type": "boolean",
      "default": true
    },
    "stay_on_seed_domain": {
      "type": "boolean",
      "default": true
    },
    "block_private_addresses": {
      "type": "boolean",
      "default": false
    },
    "allowed_domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "trace": {
      "type": "boolean",
      "default": false
    },
    "allowed_content_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "text/html",
        "application/xhtml+xml"
      ]
    }
  },
  "required": [
    "db_path",
    "transport",
    "user_agent",
    "max_pages",
    "max_depth",
    "max_response_bytes",
    "connect_timeout",
    "read_timeout",
    "total_timeout",
    "redirect_limit",
    "retry_count",
    "min_delay_seconds",
    "obey_robots",
    "stay_on_seed_domain",
    "block_private_addresses",
    "allowed_domains",
    "trace",
    "allowed_content_types"
  ]
}
