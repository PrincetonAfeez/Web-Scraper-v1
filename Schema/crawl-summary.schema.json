{
  "$id": "https://example.com/scrapehound/schema/crawl-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scrapehound Crawl Summary",
  "type": "object",
  "description": "Structured version of the CrawlSummary dataclass printed by crawl/resume.",
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "integer",
      "minimum": 1
    },
    "fetched": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "skipped": {
      "type": "integer",
      "minimum": 0
    },
    "pending": {
      "type": "integer",
      "minimum": 0
    },
    "pages": {
      "type": "integer",
      "minimum": 0
    },
    "failures": {
      "type": "integer",
      "minimum": 0
    },
    "details": {
      "type": "object",
      "properties": {
        "frontier": {
          "type": "object",
          "description": "Counts grouped by frontier status.",
          "properties": {
            "pending": {
              "type": "integer",
              "minimum": 0
            },
            "in_progress": {
              "type": "integer",
              "minimum": 0
            },
            "fetched": {
              "type": "integer",
              "minimum": 0
            },
            "skipped": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "retry_scheduled": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "job_id",
    "fetched",
    "failed",
    "skipped",
    "pending",
    "pages",
    "failures",
    "details"
  ]
}
